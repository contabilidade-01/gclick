# ============================================================
# GCLICK - Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env no GitHub!
# ============================================================

# ============================================================
# G-Click API
# ============================================================
# Obter em: https://api.gclick.com.br (painel Omie)
GCLICK_CLIENT_ID=sua_client_id_aqui
GCLICK_CLIENT_SECRET=sua_client_secret_aqui

# ============================================================
# uazapi (WhatsApp)
# ============================================================
# Obter no painel da sua instância uazapi
UAZAPI_SUBDOMAIN=seu_subdomain
UAZAPI_TOKEN=seu_token_aqui

# ============================================================
# Login da Página
# ============================================================
# Usuário para login
APP_USER=admin

# Hash bcrypt da senha
# Gerar novo hash:
#   python -c "from passlib.hash import bcrypt; print(bcrypt.hash('SUA_SENHA'))"
APP_PASSWORD_HASH=$2b$12$HASH_GERADO_AQUI

# ============================================================
# Segurança
# ============================================================
# Chave para cookies de sessão (32+ caracteres aleatórios)
# Gerar nova:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHAVE_SECRETA_MINIMO_32_CARACTERES

# ============================================================
# Configurações de Envio (opcionais)
# ============================================================
# Intervalo entre envios em segundos (padrão: 0.6)
# ENVIO_THROTTLE_S=0.6

# Máximo de envios por hora (padrão: 180)
# ENVIO_MAX_POR_HORA=180

# Intervalo de atualização do cache em horas (0 = desligado)
# REFRESH_INTERVAL_H=0

# ============================================================
# Deploy (para VPS/EasyPanel)
# ============================================================
# URL pública do app (ex: https://guias.seudominio.com)
# PUBLIC_BASE_URL=https://seudominio.com

# ---------------------------------------------------------------------------
# Portal do Cliente
# ---------------------------------------------------------------------------
# Publica cada guia enviada no portal e faz o botão do WhatsApp abrir o PORTAL
# em vez do PDF solto. Se ficar vazio, nada muda: o botão continua a usar o link
# rastreado local (/g/{token}).
# A chave tem de ser a MESMA do INGEST_API_KEY configurado no portal.
# PORTAL_INGEST_URL=https://app.gestaoempresa.com/api/fiscal/ingest
# PORTAL_INGEST_KEY=

# Host e porta do servidor
APP_HOST=127.0.0.1
APP_PORT=8000
